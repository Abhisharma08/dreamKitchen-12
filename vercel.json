{
  "buildCommand": "cd apps/web && npm install && npm run build",
  "installCommand": "npm install",
  "outputDirectory": "apps/web/dist",
  "functions": {
    "api/**/*.js": {
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
