{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "HUBSPOT_ACCESS_TOKEN": "@hubspot_access_token"
  },
  "functions": {
    "api/hubspot/index.js": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/api/:match*"
    }
  ]
}
